# NEXUS-MD Configuration
# Copy this file to .env and fill in your values

# Bot owners (format: number;name;number;name)
OWNERS=1234567890;Owner;0987654321;CoOwner

# Moderators (comma separated)
MODS=1234567890,0987654321

# Bot settings
BOTNAME=NEXUS-MD
PACKNAME=NEXUS-BOT
AUTHOR=Nexus

# Prefix (default: . / ! # $ etc)
PREFIX=.

# Mode: public or private
MODE=public

# Auto read messages
autoRead=false

# View status/stories
statusview=false

# ====== FIREBASE CONFIGURATION ======
# This bot uses Firebase FIRESTORE (not Realtime Database)
# 
# Option 1: Use service account file
# Place your firebase-service-account.json in the root directory
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Use environment variables (recommended for deployment)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# NOTE: FIREBASE_DATABASE_URL is NOT required for Firestore
# Only set this if you're also using Realtime Database features
# FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Firebase Web Config (for reference, use Admin SDK for server-side)
# FIREBASE_API_KEY=your-api-key
# FIREBASE_AUTH_DOMAIN=nexus-md.firebaseapp.com
# FIREBASE_STORAGE_BUCKET=nexus-md.firebasestorage.app

# ====== API KEYS (Optional) ======
# OpenAI API for GPT/DALL-E
# OPENAI_API_KEY=your-openai-api-key

# Remove.bg API for background removal
# REMOVEBG_API_KEY=your-removebg-api-key
